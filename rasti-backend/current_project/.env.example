# Rasti Service - Environment Variables
# Copy this to .env and fill in values

# Django
DEBUG=True
DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DB_NAME=rasti_service
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Or use a full DATABASE_URL instead of individual DB_* vars:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# CSRF (include protocol in production)
CSRF_TRUSTED_ORIGINS=http://localhost:8000

# Production only
# SECURE_SSL_REDIRECT=True
